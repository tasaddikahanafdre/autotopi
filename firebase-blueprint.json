{
  "entities": {
    "Banner": {
      "title": "Banner",
      "description": "Visual promotional banner shown on the home page carousel.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique banner ID" },
        "imageUrl": { "type": "string", "description": "URL of the background image" },
        "title": { "type": "string", "description": "Banner headline" },
        "subtitle": { "type": "string", "description": "Subheading or additional details" },
        "ctaText": { "type": "string", "description": "Text inside CTA button" },
        "ctaLink": { "type": "string", "description": "Target section or link for the CTA" }
      },
      "required": ["id", "imageUrl", "title"]
    },
    "NewsPost": {
      "title": "NewsPost",
      "description": "Automotive news story or review article.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique post ID" },
        "title": { "type": "string", "description": "Title of the post" },
        "excerpt": { "type": "string", "description": "Short description shown on previews" },
        "content": { "type": "string", "description": "Full Markdown article text content" },
        "category": { "type": "string", "description": "Category tags, e.g., Launches, Reviews" },
        "imageUrl": { "type": "string", "description": "Cover picture URL" },
        "publishDate": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "author": { "type": "string", "description": "Desk or writer name" }
      },
      "required": ["id", "title", "content", "imageUrl", "publishDate"]
    },
    "VideoItem": {
      "title": "VideoItem",
      "description": "YouTube video link posted by the team.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique video ID" },
        "title": { "type": "string", "description": "Display title of the video" },
        "description": { "type": "string", "description": "Short YouTube clip summary" },
        "youtubeUrl": { "type": "string", "description": "Original YouTube watch link" },
        "youtubeId": { "type": "string", "description": "Parsed YouTube video ID" },
        "publishDate": { "type": "string", "description": "Publication date" }
      },
      "required": ["id", "title", "youtubeUrl", "youtubeId"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "User submit inquiry message.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Inquiry identifier" },
        "name": { "type": "string", "description": "Sender name" },
        "email": { "type": "string", "description": "Sender email" },
        "phone": { "type": "string", "description": "Optional sender phone" },
        "subject": { "type": "string", "description": "Subject of interest" },
        "message": { "type": "string", "description": "Message content text" },
        "status": { "type": "string", "enum": ["pending", "completed"], "description": "Message status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp" }
      },
      "required": ["id", "name", "email", "message", "status", "createdAt"]
    },
    "WebsiteSettings": {
      "title": "WebsiteSettings",
      "description": "Global custom website configuration parameters.",
      "type": "object",
      "properties": {
        "logoText": { "type": "string", "description": "Header title text brand" },
        "tagline": { "type": "string", "description": "Platform slogan tagline" },
        "address": { "type": "string", "description": "Office address" },
        "helpline": { "type": "string", "description": "Direct helpline contact phone" },
        "email": { "type": "string", "description": "Autotopi email" },
        "youtubeUrl": { "type": "string", "description": "Team YouTube branding address" },
        "facebookUrl": { "type": "string", "description": "Team Facebook social address" },
        "instagramUrl": { "type": "string", "description": "Team Instagram social address" },
        "copyright": { "type": "string", "description": "Footer copyright line text" }
      },
      "required": ["logoText", "tagline", "email", "copyright"]
    },
    "InAppNotification": {
      "title": "InAppNotification",
      "description": "Notification broadcast triggered when the admin uploads content.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Notification unique ID" },
        "title": { "type": "string", "description": "Notification title to display" },
        "text": { "type": "string", "description": "Details text summary" },
        "type": { "type": "string", "description": "Dynamic upload model: banner, news, video" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Trigger timestamp" }
      },
      "required": ["id", "title", "text", "createdAt"]
    }
  },
  "firestore": {
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "List of slides in homepage carousel."
    },
    "/news/{postId}": {
      "schema": "NewsPost",
      "description": "Collection of review documents and launches news."
    },
    "/videos/{videoId}": {
      "schema": "VideoItem",
      "description": "List of curated Youtube videoclips."
    },
    "/messages/{messageId}": {
      "schema": "ContactMessage",
      "description": "Collection of visitor inquiries submitted from index form."
    },
    "/settings/global": {
      "schema": "WebsiteSettings",
      "description": "Single record containing configurations."
    },
    "/notifications/{notificationId}": {
      "schema": "InAppNotification",
      "description": "Collection of broadcast alerts for uploaded content."
    }
  }
}
